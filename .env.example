# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# USE_MOCK_OTP: Enable or disable mock OTP (123456) in development mode.
# Set to 'true' to use mock OTP, 'false' to use real Fast2SMS API.
USE_MOCK_OTP="true"

# FIREBASE_SERVICE_ACCOUNT_KEY: (Optional) A stringified JSON string of your Firebase 
# Service Account Key. Required for Admin functionalities like deeply deleting User Authentication instances.
FIREBASE_SERVICE_ACCOUNT_KEY=""

CUSTOM_GEMINI_API_KEY=""
