# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_BACKEND_URL: The full URL of the Render (or other) backend server.
# The frontend uses this to call API endpoints when hosted separately (e.g. Firebase Hosting).
# Leave empty for local dev where frontend and backend run on the same origin.
VITE_BACKEND_URL=""

# USE_MOCK_OTP: Enable or disable mock OTP (123456) in development mode.
# Set to 'true' to use mock OTP, 'false' to use real Fast2SMS API.
USE_MOCK_OTP="true"

# FIREBASE_SERVICE_ACCOUNT_KEY: (Required for production) A stringified JSON string of your Firebase 
# Service Account Key. Required for:
#   - Server-side Firestore access (cart persistence, user data)
#   - Admin functionalities (deleting users from Firebase Auth)
#   - Verifying Firebase ID tokens on API endpoints
# Go to Firebase Console → Project Settings → Service Accounts → Generate New Private Key.
# Copy the entire JSON, stringify it, and paste it here.
FIREBASE_SERVICE_ACCOUNT_KEY=""

CUSTOM_GEMINI_API_KEY=""
